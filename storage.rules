rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // この現場のオーナー（作った職長）か（Firestoreのsites/{現場コード}を参照して判定）
    function isOwner(site) {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/sites/$(site)).data.ownerUid == request.auth.uid;
    }

    // ===== 現場の写真 =====
    match /sites/{site}/photos/{file} {
      // 表示：ログイン済み（職長・作業員）なら可
      allow read: if request.auth != null;
      // アップロード：その現場のオーナーのみ。画像・2MB未満に制限
      allow create, update: if isOwner(site)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // 削除：その現場のオーナーのみ
      allow delete: if isOwner(site);
    }

    // 上記以外の場所は読み書き禁止
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
